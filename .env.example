# Supabase — create a project at https://supabase.com and paste values here.
# Copy this file to .env.local for local dev; set the same vars in Vercel for production.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by admin routes (match resolver, manual sync trigger) in later phases.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the admin-sync/resolve routes will require in an Authorization header.
RESOLVE_SECRET=
